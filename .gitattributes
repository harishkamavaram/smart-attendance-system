# Auto-detect text files
* text=auto

# Maven Wrapper
/mvnw text eol=lf
*.cmd text eol=crlf

# Shell scripts
*.sh text eol=lf

# Java
*.java text diff=java

# YAML
*.yml text
*.yaml text

# Properties
*.properties text

# Markdown
*.md text

# JSON
*.json text

# XML
*.xml text

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary