```gitignore
# ========================================
# Operating System
# ========================================
.DS_Store
Thumbs.db
Desktop.ini
.AppleDouble
.LSOverride
ehthumbs.db

# ========================================
# IDE / Editors
# ========================================
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.factorypath
.settings/
.apt_generated
.springBeans
.sts4-cache
.metadata/

# ========================================
# Java / Maven
# ========================================
**/target/
!**/src/main/**/target/
!**/src/test/**/target/
.metadata/
**/.metadata/

HELP.md

*.log
**/logs/

# Maven Wrapper (Keep these)
#!**/.mvn/
#!**/mvnw
#!**/mvnw.cmd


# ========================================
# Node.js / React
# ========================================
**/node_modules/
**/dist/
**/.vite/
**/.next/
**/coverage/

# ========================================
# Python
# ========================================
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/

# ========================================
# Environment Variables
# ========================================
.env
.env.*
!.env.example

# ========================================
# Docker
# ========================================
docker-data/

# ========================================
# Temporary Files
# ========================================
*.tmp
*.bak
*.swp
```

# ========================================
# Application Properties 
# ========================================
**/application.properties